# Neo4j AuraDB
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (local or Upstash)
REDIS_URL=redis://localhost:6379

# Reka Vision API
REKA_API_KEY=

# Yutori Browsing API
YUTORI_API_KEY=

# Pioneer API (GLiNER XL 1B — optional, for high-stakes claims)
PIONEER_API_KEY=

# Storage
UPLOAD_DIR=./uploads

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Pioneer cloud model (set after training job completes)
PIONEER_BASE_URL=https://api.gliner.pioneer.ai
PIONEER_MODEL_JOB_ID=
